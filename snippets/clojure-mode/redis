# key: redis
# name: redis
# --
(require '[taoensso.carmine :as redis])

(defonce redis-pool
  (redis/connection-pool {}))

(def redis-spec
  {:uri "http://localhost:${1:6379}"})

(def redis-options
  {:pool redis-pool :spec redis-spec})

(defmacro redis
  [& body]
  `(redis/wcar redis-options ~@body))

(redis (redis/ping))